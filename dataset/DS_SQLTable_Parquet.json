{
	"name": "DS_SQLTable_Parquet",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_SQLTable_Parquet",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Table_Name": {
				"type": "string",
				"defaultValue": "@pipeline().parameter.TableName"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": "@concat(dataset().Table_Name,'_',formatDateTime(utcNow(),'yyyyMMddHHmmss'),'.parquet')",
				"folderPath": "@concat(dataset().Table_Name,'/',formatDateTime(utcNow(),'yyyy/MM/dd’))"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	}
}